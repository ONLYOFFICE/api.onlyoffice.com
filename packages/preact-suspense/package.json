{
  "name": "@onlyoffice/preact-suspense",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf coverage node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test:unit": "c8 --config ../../c8.config.json tsx node_modules/uvu/bin.js lib ^.*\\.test\\.tsx$",
    "test": "pnpm test:types && pnpm test:unit"
  },
  "dependencies": {
    "@onlyoffice/preact-types": "workspace:^",
    "preact": "10.22.0"
  },
  "devDependencies": {
    "c8": "9.1.0",
    "esbuild": "0.23.0",
    "preact-render-to-string": "6.4.1",
    "rimraf": "6.0.1",
    "tsx": "4.16.5",
    "typescript": "5.4.5",
    "uvu": "0.5.6"
  }
}
