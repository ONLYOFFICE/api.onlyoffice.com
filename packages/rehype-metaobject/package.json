{
  "name": "@onlyoffice/rehype-metaobject",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf coverage node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test:unit": "c8 --config ../../c8.config.json tsx node_modules/uvu/bin.js lib ^.*\\.test\\.ts$",
    "test": "pnpm test:types && pnpm test:unit"
  },
  "dependencies": {
    "@types/hast": "3.0.4",
    "json5": "2.2.3",
    "unist-util-visit": "5.0.0"
  },
  "devDependencies": {
    "@onlyoffice/rehype-metastring": "workspace:^",
    "@types/node": "20.12.12",
    "c8": "9.1.0",
    "esbuild": "0.23.0",
    "rehype-raw": "7.0.0",
    "rehype-stringify": "10.0.0",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.0",
    "rimraf": "6.0.1",
    "tsx": "4.16.5",
    "typescript": "5.4.5",
    "unified": "11.0.5",
    "uvu": "0.5.6"
  }
}
