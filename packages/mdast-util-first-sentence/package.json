{
  "name": "@onlyoffice/mdast-util-first-sentence",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf coverage node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test:unit": "c8 --config ../../c8.config.json tsx node_modules/uvu/bin.js lib ^.*\\.test\\.ts$",
    "test": "pnpm test:types && pnpm test:unit"
  },
  "dependencies": {
    "@onlyoffice/mdast-util-is-node": "workspace:^",
    "@types/mdast": "4.0.3",
    "mdast-util-to-string": "4.0.0",
    "sentence-splitter": "5.0.0"
  },
  "devDependencies": {
    "c8": "9.1.0",
    "esbuild": "0.23.0",
    "mdast-util-from-markdown": "2.0.0",
    "mdast-util-to-markdown": "2.1.0",
    "rimraf": "6.0.1",
    "tsx": "4.16.5",
    "typescript": "5.4.5",
    "uvu": "0.5.6"
  }
}
