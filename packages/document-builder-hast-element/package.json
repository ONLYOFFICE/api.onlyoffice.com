{
  "name": "@onlyoffice/document-builder-hast-element",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test:unit": "c8 --config ../../c8.config.json tsx node_modules/uvu/bin.js lib ^.*\\.test\\.ts$",
    "test": "pnpm test:types && pnpm test:unit"
  },
  "dependencies": {
    "@onlyoffice/document-builder-html-element": "workspace:^",
    "@onlyoffice/document-editor-hast-element": "workspace:^",
    "typescript": "5.4.5"
  },
  "devDependencies": {
    "@onlyoffice/document-editor-html-element": "workspace:^",
    "@types/hast": "3.0.4",
    "c8": "9.1.0",
    "esbuild": "0.23.0",
    "hast-util-to-html": "9.0.1",
    "rimraf": "6.0.1",
    "tsx": "4.16.5",
    "uvu": "0.5.6"
  }
}
