{
  "name": "@onlyoffice/openapi-resource",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test": "pnpm test:types"
  },
  "dependencies": {
    "@onlyoffice/console": "workspace:^",
    "@onlyoffice/jq": "workspace:^",
    "@onlyoffice/node-path": "workspace:^",
    "@onlyoffice/openapi-declaration": "workspace:^",
    "@onlyoffice/resource": "workspace:^",
    "@onlyoffice/service-resource": "workspace:^",
    "@onlyoffice/stream-string": "workspace:^",
    "@types/node": "20.12.12",
    "@types/stream-json": "1.7.7",
    "openapi-types": "12.1.3",
    "stream-json": "1.8.0"
  },
  "devDependencies": {
    "esbuild": "0.23.0",
    "rimraf": "6.0.1",
    "typescript": "5.4.5"
  }
}
