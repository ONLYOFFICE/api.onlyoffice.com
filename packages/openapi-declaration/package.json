{
  "name": "@onlyoffice/openapi-declaration",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf coverage node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test:unit": "c8 --config ../../c8.config.json tsx node_modules/uvu/bin.js lib ^.*\\.test\\.ts$",
    "test": "pnpm test:types && pnpm test:unit"
  },
  "dependencies": {
    "@onlyoffice/console": "workspace:^",
    "@onlyoffice/service-declaration": "workspace:^",
    "@onlyoffice/service-signature": "workspace:^",
    "@types/node": "20.12.12",
    "openapi-types": "12.1.3"
  },
  "devDependencies": {
    "c8": "9.1.0",
    "esbuild": "0.23.0",
    "is-valid-uuid-v4": "1.2.3",
    "rimraf": "6.0.1",
    "tsx": "4.16.5",
    "typescript": "5.4.5",
    "uvu": "0.5.6"
  }
}
