{
  "name": "@onlyoffice/jsdoc-declaration",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/**/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test": "pnpm test:types"
  },
  "dependencies": {
    "@onlyoffice/async-transform": "workspace:^",
    "@onlyoffice/console": "workspace:^",
    "@onlyoffice/declaration-code-example": "workspace:^",
    "@onlyoffice/eslint-config": "workspace:^",
    "@onlyoffice/jsdoc": "workspace:^",
    "@onlyoffice/library-declaration": "workspace:^",
    "@onlyoffice/library-signature": "workspace:^",
    "@onlyoffice/mdast-util-extract-section": "workspace:^",
    "@onlyoffice/mdast-util-first-sentence": "workspace:^",
    "@onlyoffice/signature": "workspace:^",
    "@onlyoffice/strings": "workspace:^",
    "@types/mdast": "4.0.3",
    "@types/node": "20.12.12",
    "@vscode/vscode-languagedetection": "1.0.22",
    "mdast-util-from-markdown": "2.0.0",
    "mdast-util-to-markdown": "2.1.0",
    "unist-util-select": "5.1.0",
    "unist-util-visit": "5.0.0"
  },
  "devDependencies": {
    "esbuild": "0.23.0",
    "rimraf": "6.0.1",
    "typescript": "5.4.5"
  }
}
