{
  "name": "@onlyoffice/preact-eleventy-img",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test": "pnpm test:types"
  },
  "dependencies": {
    "@11ty/eleventy-img": "4.0.2",
    "@onlyoffice/preact-types": "workspace:^",
    "@types/11ty__eleventy-img": "4.0.0",
    "preact": "10.22.0"
  },
  "devDependencies": {
    "esbuild": "0.23.0",
    "rimraf": "6.0.1",
    "typescript": "5.4.5"
  }
}
