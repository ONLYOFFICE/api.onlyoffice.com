{
  "name": "@onlyoffice/rehype-clean",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "clean": "rimraf node_modules",
    "build:code": "esbuild --outdir=dist --tsconfig=tsconfig.emit.json --sourcemap lib/*",
    "build:types": "tsc --project tsconfig.emit.json",
    "build": "pnpm build:types && pnpm build:code",
    "test:types": "tsc",
    "test": "pnpm test:types"
  },
  "dependencies": {
    "@types/hast": "3.0.4",
    "unist-util-visit": "5.0.0"
  },
  "devDependencies": {
    "@onlyoffice/rehype-metaobject": "workspace:^",
    "@onlyoffice/rehype-metastring": "workspace:^",
    "esbuild": "0.23.0",
    "rimraf": "6.0.1",
    "typescript": "5.4.5"
  }
}
